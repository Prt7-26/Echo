# Built frontend artifacts (regenerated by build scripts)
hermes_cli/web_dist/
hermes_cli/tui_dist/
web/dist/
ui-tui/dist/
# NOTE: plugins/*/dashboard/dist/ is intentionally tracked. Those
# bundles are hand-written IIFE files (see hermes-achievements/, Echo,
# etc.) consuming the SDK exposed at window.__HERMES_PLUGIN_SDK__, not
# build output. pyproject.toml package-data ships them with the wheel.

# --- Editor / IDE ---
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.cursor/

# --- OS junk ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Hermes runtime state (NEVER commit user data / secrets) ---
.hermes/
hermes-profile-*/
*.db
*.db-journal
*.db-wal
*.db-shm
logs/
*.log

# --- Secrets / credentials ---
.env.local
.env.*.local
*.pem
*.key
credentials.json
secrets.yaml
config.yaml
!cli-config.yaml.example

# --- Debugging / scratch ---
*.bak
*.orig
*.rej
scratch/
tmp/
.tmp/

# LaTeX build artifacts (DevPlan/document.tex sources stay; build outputs don't).
DevPlan/*.aux
DevPlan/*.out
DevPlan/*.log
DevPlan/*.synctex.gz

# Agent-generated architecture diagrams dropped in the repo root during
# dashboard testing (e.g. macos-architecture.html, microservice-architecture.html).
# Root-anchored so docs/hermes-architecture.html (tracked) is unaffected.
/*-architecture*.html
