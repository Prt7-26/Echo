# --- Virtual environments ---
venv/
.venv/
env/
.env
ENV/

# --- uv / pip ---
.uv-cache/
pip-log.txt

# --- Node / Web frontends (web/, ui-tui/, plugins/*/dashboard/) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
*.tsbuildinfo
.next/
