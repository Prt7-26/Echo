{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Echo",
  "version": "0.1.0",
  "identifier": "ai.echo.shell",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../src",
    "devUrl": "http://127.0.0.1:9119"
  },
  "app": {
    "windows": [
      {
        "title": "Echo",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "url": "http://127.0.0.1:9119/echo",
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Echo desktop shell",
    "longDescription": "Tauri wrapper around the Hermes Echo dashboard. Provides OS clipboard + window-focus signals that the browser sandbox cannot capture, feeding Echo's Layer A signal collection."
  },
  "plugins": {}
}
