#!/usr/bin/env bash
# Echo launcher — start Hermes + Echo plugin in the flavor you want.
#
# Usage:  ./echo <command> [args...]
# Run    ./echo --help    for the full list.

set -euo pipefail

REPO_ROOT="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$REPO_ROOT"

DASH_HOST="${ECHO_DASH_HOST:-127.0.0.1}"
DASH_PORT="${ECHO_DASH_PORT:-9119}"
PID_DIR="${TMPDIR:-/tmp}"
DASH_PID_FILE="${PID_DIR%/}/echo-dashboard.pid"
DASH_LOG_FILE="${PID_DIR%/}/echo-dashboard.log"

c_dim()  { printf '\033[2m%s\033[0m\n' "$*"; }
c_ok()   { printf '\033[32m%s\033[0m\n' "$*"; }
c_warn() { printf '\033[33m%s\033[0m\n' "$*" >&2; }
c_err()  { printf '\033[31m%s\033[0m\n' "$*" >&2; }

# Resolve a Python interpreter that has Hermes' web deps installed AND
# can see Echo's source as the highest-priority hermes_cli.
#
# We deliberately do NOT use the `hermes` shim on PATH: it's a console-script
# entry point, so sys.path[0] is the venv bin/ rather than CWD, which makes
# `import hermes_cli` resolve to whatever's in the venv site-packages —
# typically the upstream Hermes install at ~/.hermes/hermes-agent/, NOT this
# repo. That's why /echo would 404 (echo_signals not in bundled plugins) and
# the chat:bottom thumbs widget never showed up.
#
# Using `<py> -m hermes_cli.main` from REPO_ROOT puts CWD on sys.path first,
# so Echo's hermes_cli wins and get_bundled_plugins_dir() points at
# ./plugins/ (which contains echo_signals).
resolve_python() {
  local probe candidates=(
    "${ECHO_PYTHON:-}"
    "${VIRTUAL_ENV:+$VIRTUAL_ENV/bin/python}"
    "$HOME/.hermes/hermes-agent/venv/bin/python"
    "$(command -v python3 2>/dev/null || true)"
  )
  for probe in "${candidates[@]}"; do
    [[ -z "$probe" || ! -x "$probe" ]] && continue
    "$probe" -c "import fastapi, uvicorn" >/dev/null 2>&1 && { echo "$probe"; return 0; }
  done
  # Fall back to plain python3 even without fastapi — `chat`/`tui` don't
  # need it, only the dashboard does.  We'll print a warning if dashboard
  # is requested with a deps-poor interpreter.
  [[ -n "${candidates[3]:-}" ]] && { echo "${candidates[3]}"; return 0; }
  return 1
}

PYBIN="$(resolve_python || true)"
if [[ -z "$PYBIN" ]]; then
  c_err "Couldn't find a usable Python.  Set ECHO_PYTHON to a Python that can 'import hermes_cli'."
  exit 1
fi

# Pin the Python used by every subprocess in the Hermes chain.
#
# Without this: ui-tui/gatewayClient.ts:36 falls back to $VIRTUAL_ENV/bin/python,
# which on this machine is an active anaconda env without openai/uvicorn.
# The dashboard would start fine in $PYBIN but the embedded chat would crash
# with "Failed to initialize OpenAI client: No module named 'openai'".
#
# Exporting HERMES_PYTHON makes ui-tui / tui_gateway / any other Python-spawning
# Node code use the same interpreter that runs Hermes proper.
export HERMES_PYTHON="$PYBIN"

hermes_cli() {
  # Always invoke via -m so CWD (REPO_ROOT) wins on sys.path and Echo's
  # source is what runs.  $PYBIN provides the deps.
  "$PYBIN" -m hermes_cli.main "$@"
}

usage() {
  cat <<'EOF'
Echo launcher — one entry point for every Hermes + Echo flavor.

USAGE
  ./echo <command> [args...]

COMMANDS
  chat [args]    Hermes CLI chat (Echo collects signals in background).
                 Extra args are forwarded, e.g. ./echo chat --resume <id>.
  tui [args]     Hermes full-screen TUI.
  dash [args]    Hermes Web Dashboard (foreground).  Browser opens to /echo.
                 Extra args forwarded to `hermes dashboard`.
  app [--connect] [--debug]
                 Native macOS app (Echo, Liquid Glass / new-Siri look).
                 Default = mock walkthrough + release build (smooth);
                 --connect spawns the live gateway; --debug = fast-iterate build.
  app-check      Run Echo's self-check harness (swift run echo-check).
  verify         Run Echo unit tests + scripts/verify_echo.py smoke check.
  status         Show whether the background dashboard is up.
  stop           Stop the background dashboard started by ./echo.
  -h, --help     Show this help.

ENV VARS
  ECHO_DASH_HOST   Dashboard host  (default 127.0.0.1)
  ECHO_DASH_PORT   Dashboard port  (default 9119)

EXAMPLES
  ./echo chat                       # quick chat session
  ./echo dash                       # open the dashboard
  ./echo app                        # native macOS app (mock walkthrough)
  ECHO_DASH_PORT=9200 ./echo dash   # use a different port
  ./echo verify                     # confirm Echo is healthy
EOF
}

dash_is_up() {
  curl -sf "http://${DASH_HOST}:${DASH_PORT}/api/plugins/echo_signals/status" \
       >/dev/null 2>&1
}

start_dashboard_bg() {
  if dash_is_up; then
    c_dim "Dashboard already up at http://${DASH_HOST}:${DASH_PORT}"
    return 0
  fi
  echo "Starting dashboard in background on ${DASH_HOST}:${DASH_PORT} ..."
  nohup "$PYBIN" -m hermes_cli.main dashboard \
        --host "$DASH_HOST" --port "$DASH_PORT" --no-open \
        >"$DASH_LOG_FILE" 2>&1 &
  echo $! > "$DASH_PID_FILE"
  for _ in $(seq 1 30); do
    if dash_is_up; then
      c_ok "Dashboard ready (pid $(cat "$DASH_PID_FILE"), log: $DASH_LOG_FILE)"
      return 0
    fi
    sleep 1
  done
  c_err "Dashboard didn't come up in 30s — check $DASH_LOG_FILE"
  return 1
}

stop_dashboard_bg() {
  if [[ -f "$DASH_PID_FILE" ]]; then
    local pid
    pid="$(cat "$DASH_PID_FILE")"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      echo "Stopping background dashboard (pid $pid) ..."
      kill "$pid" 2>/dev/null || true
      # Give it a moment, then SIGKILL if still alive.
      for _ in 1 2 3; do
        kill -0 "$pid" 2>/dev/null || break
        sleep 1
      done
      kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true
    fi
    rm -f "$DASH_PID_FILE"
  else
    c_dim "No background dashboard PID file."
  fi
}


# Install Echo's skin into <hermes_home>/skins/ and make it the default —
# but only when display.skin is still "default" (i.e. the user never chose
# a skin). A user who explicitly picked another skin (/skin ares etc.) is
# left alone. Caveat: `/skin default` reads as "never chose", so the next
# ./echo launch flips back to echo — use any other skin or launch bare
# `hermes` to keep the stock look. Idempotent + best-effort: a failure
# here must never block startup.
install_echo_skin() {
  "$PYBIN" - <<'PY' 2>/dev/null || true
import shutil, sys
from pathlib import Path
sys.path.insert(0, ".")

from hermes_constants import get_hermes_home

skins_dir = get_hermes_home() / "skins"
# Install both the dark (echo) and light (echo-light) skins. The light one
# is used by the dashboard's embedded chat terminal when the web theme is
# light (web_server sets HERMES_SKIN=echo-light per session).
for stem in ("echo", "echo-light"):
    src = Path(f"plugins/echo_signals/skin/{stem}.yaml")
    dst = skins_dir / f"{stem}.yaml"
    if src.exists():
        dst.parent.mkdir(parents=True, exist_ok=True)
        if not dst.exists() or dst.read_bytes() != src.read_bytes():
            shutil.copy2(src, dst)

from hermes_cli.config import load_config, save_config

cfg = load_config()
display = cfg.setdefault("display", {})
if display.get("skin", "default") == "default":
    display["skin"] = "echo"
    save_config(cfg)
PY
}

cmd="${1:-}"
[[ $# -gt 0 ]] && shift

case "$cmd" in
  chat)
    install_echo_skin
    exec "$PYBIN" -m hermes_cli.main chat "$@"
    ;;
  tui)
    install_echo_skin
    exec "$PYBIN" -m hermes_cli.main --tui "$@"
    ;;
  dash|dashboard)
    install_echo_skin
    exec "$PYBIN" -m hermes_cli.main dashboard --host "$DASH_HOST" --port "$DASH_PORT" "$@"
    ;;
  app)
    # 原生 macOS App (Echo, Liquid Glass)。默认 mock 走查；
    # 加 --connect 用 stdio 子进程接真后端 gateway。
    if ! command -v swift >/dev/null 2>&1; then
      c_err "swift not found — install Xcode 26 or Command Line Tools"
      exit 1
    fi
    connect=0; conf="release"
    for a in "$@"; do
      [[ "$a" == "--connect" ]] && connect=1
      [[ "$a" == "--debug" ]] && conf="debug"   # 快速迭代用 debug；默认 release 更流畅
    done
    export ECHO_REPO_ROOT="$REPO_ROOT"
    export HERMES_PYTHON="$PYBIN"
    if [[ "$connect" == "1" ]]; then
      export ECHO_APP_CONNECT=1
      c_dim "Echo: connecting to live gateway (spawns python -m tui_gateway.entry)"
    else
      c_dim "Echo: mock walkthrough (no backend). add --connect for live."
    fi
    # 默认 release：SwiftUI 的 debug 构建慢一个数量级，是开发期卡顿的头号原因。
    [[ "$conf" == "release" ]] && c_dim "Echo: release build (first build is slower; add --debug for fast iterate)."
    cd desktop/Echo
    exec swift run -c "$conf" Echo
    ;;
  app-check)
    # 跑 Echo 自检 harness（CLT 下 XCTest 替代）。
    export ECHO_REPO_ROOT="$REPO_ROOT"
    export HERMES_PYTHON="$PYBIN"
    cd desktop/Echo
    exec swift run echo-check
    ;;
  verify)
    python3 -m pytest tests/plugins/echo_signals/ -o addopts="" -q
    echo
    python3 scripts/verify_echo.py
    ;;
  status)
    if dash_is_up; then
      c_ok "Dashboard: UP   http://${DASH_HOST}:${DASH_PORT}"
    else
      c_dim "Dashboard: down (http://${DASH_HOST}:${DASH_PORT})"
    fi
    if [[ -f "$DASH_PID_FILE" ]]; then
      pid="$(cat "$DASH_PID_FILE")"
      if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
        echo "Background pid: $pid  (log: $DASH_LOG_FILE)"
      else
        c_warn "Stale PID file at $DASH_PID_FILE (process $pid is gone)"
      fi
    fi
    ;;
  stop)
    stop_dashboard_bg
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    c_err "Unknown command: $cmd"
    echo
    usage
    exit 2
    ;;
esac
